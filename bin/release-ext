#!/bin/bash

# Set variables
OUTPUT_DIR="./web-ext/build"

CHROME_DIR="./web-ext/chrome"
FF_DIR="./web-ext/ff"

# Create output directory if it doesn't exist
mkdir -p "$OUTPUT_DIR"

# Function to create a zip file
create_zip() {
  local source_dir=$1
  local output_file=$2
  local dir_name=$(basename "$source_dir")

  echo "Creating $output_file from $source_dir..."

  # Navigate to the source directory and create a zip file with relative paths
  cd "$source_dir" || exit 1
  zip -r "../../$OUTPUT_DIR/$output_file" ./* -x "*.DS_Store" "*__MACOSX*"
  cd - >/dev/null || exit 1

  echo "✅ Created $OUTPUT_DIR/$output_file"
}

# Clean any existing zip files
rm -f "$OUTPUT_DIR"/*.zip

# Create zip files
create_zip "$CHROME_DIR" "chrome-extension.zip"
create_zip "$FF_DIR" "firefox-extension.zip"

# Open the output directory
open "$OUTPUT_DIR"

# Open the developer console URLs
open "https://chrome.google.com/u/1/webstore/devconsole/549f90d7-d695-40f5-bc0a-8ae2960da6aa/knknjjghhkppgfkkclcdefohkfdnhfan/edit/package"
open "https://addons.mozilla.org/en-US/developers/addon/getsprinkles/versions/submit/"

echo "✅ All tasks completed"
