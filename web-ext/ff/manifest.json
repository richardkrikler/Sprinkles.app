{
  "manifest_version": 3,
  "name": "Sprinkles",
  "description": "The Sprinkles bread and butter",
  "version": "1.4.2",
  "icons": {
    "16": "images/icon-16.png",
    "32": "images/icon-32.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  },
  "action": {
    "default_icon": {
      "16": "images/toolbar-icon-16.png",
      "32": "images/toolbar-icon-32.png"
    },
    "default_title": "Reload user scripts",
    "theme_icons": [
      {
        "light": "images/toolbar-icon-dark-16.png",
        "dark": "images/toolbar-icon-16.png",
        "size": 16
      },
      {
        "light": "images/toolbar-icon-dark-32.png",
        "dark": "images/toolbar-icon-32.png",
        "size": 32
      }
    ]
  },
  "permissions": ["scripting", "webNavigation"],
  "options_ui": {
    "page": "options.html"
  },
  "optional_permissions": ["userScripts"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "scripts": ["sw.js"]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "{588f4ebd-9540-4f57-943d-04c682e96db9}"
    }
  }
}
